                          <KeepTogether>true</KeepTogether>
                          <Paragraphs>
                            <Paragraph>
                              <TextRuns>
                                <TextRun>
                                  <Value>=Microsoft.VisualBasic.Interaction.IIF(Fields!Doct_Type.Value = "", "Journal", Fields!Doct_Type.Value)</Value>
