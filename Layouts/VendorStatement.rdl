                      <CellContents>
                        <Textbox Name="Textbox329">
                          <rd:DefaultName>Textbox329</rd:DefaultName>
                          <CanGrow>true</CanGrow>
                          <KeepTogether>true</KeepTogether>
                          <Paragraphs>
                            <Paragraph>
                              <TextRuns>
                                <TextRun>
                                  <Value>=(IIF(Fields!CustOpAmt.Value&lt;0,Fields!CustOpAmt.Value,0))*-1</Value>
                                  <Style>
                                    <FontSize>8pt</FontSize>
                                    <FontWeight>Bold</FontWeight>
                                    <Format>#,0.00</Format>
                                  </Style>
                                </TextRun>
                                <TextRun>
                                  <Value>=iif(((IIF(Fields!CustOpAmt.Value&gt;0,Fields!CustOpAmt.Value,0))*-1)&gt;0,"Dr","Cr")</Value>
                                  <Style>
                                    <FontSize>7pt</FontSize>
                                    <FontWeight>Bold</FontWeight>
                                    <Format>#,0.00</Format>
                                  </Style>
                                </TextRun>
                              </TextRuns>
                              <Style />
                            </Paragraph>
                          </Paragraphs>
